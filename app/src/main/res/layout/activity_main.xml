<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">
    <FrameLayout
        android:id="@+id/fragment_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true" />



    <FrameLayout
        android:id="@+id/bottom"
        android:layout_alignParentBottom="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#00000000">



        <com.lihang.ShadowLayout
            android:id="@+id/navigation"
            app:hl_layoutBackground="#00000000"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hl_cornerRadius_leftTop="@dimen/dp_20"
            app:hl_cornerRadius_rightTop="@dimen/dp_20"
            app:hl_shadowHiddenBottom="true"
            app:hl_shadowLimit="@dimen/dp_3">



            <com.company.wingstars.view.TabButtonGroup
                android:layout_gravity="bottom"
                android:background="@color/white"
                android:id="@+id/tab_group"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_66"
                android:orientation="horizontal">

                <com.company.wingstars.view.TabButton
                    android:id="@+id/home"
                    android:layout_marginTop="@dimen/dp_5"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:tbn_checked="true"
                    app:tbn_icon_array_id="@array/main_tab_home"
                    app:tbn_icon_size="@dimen/dp_20"
                    app:tbn_text_color_checked="@color/color_E2518D"
                    app:tbn_text_color_unchecked="@color/color_D1D5DC"
                    app:tbn_text_size="@dimen/sp_12"
                    app:tbn_tip="@string/main_home" />

                <com.company.wingstars.view.TabButton
                    android:id="@+id/count"
                    android:layout_marginTop="@dimen/dp_5"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="match_parent"
                    android:layout_marginRight="@dimen/dp_70"
                    android:layout_weight="1"
                    app:tbn_icon_array_id="@array/main_tab_count"
                    app:tbn_icon_size="@dimen/dp_20"
                    app:tbn_text_color_checked="@color/color_E2518D"
                    app:tbn_text_color_unchecked="@color/color_D1D5DC"
                    app:tbn_text_size="@dimen/sp_12"
                    app:tbn_tip="@string/count" />

                <com.company.wingstars.view.TabButton
                    android:id="@+id/calendar"
                    android:layout_marginTop="@dimen/dp_5"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:tbn_icon_array_id="@array/main_tab_calendar"
                    app:tbn_icon_size="@dimen/dp_20"
                    app:tbn_text_color_checked="@color/color_E2518D"
                    app:tbn_text_color_unchecked="@color/color_D1D5DC"
                    app:tbn_text_size="@dimen/sp_12"
                    app:tbn_tip="@string/calendar" />

                <com.company.wingstars.view.TabButton
                    android:id="@+id/user"
                    android:layout_marginTop="@dimen/dp_5"
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    app:tbn_icon_array_id="@array/main_tab_member"
                    app:tbn_icon_size="@dimen/dp_20"
                    app:tbn_text_color_checked="@color/color_E2518D"
                    app:tbn_text_color_unchecked="@color/color_D1D5DC"
                    app:tbn_text_size="@dimen/sp_12"
                    app:tbn_tip="@string/user" />

            </com.company.wingstars.view.TabButtonGroup>


        </com.lihang.ShadowLayout>
    </FrameLayout>

    <com.lihang.ShadowLayout
        android:id="@+id/member"
        app:hl_shadowHiddenBottom="true"
        android:layout_marginBottom="@dimen/dp_15"
        app:hl_cornerRadius="@dimen/dp_50"
        app:hl_layoutBackground="#0a000000"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_width="@dimen/dp_75"
        android:layout_height="@dimen/dp_75">


        <ImageView
            android:id="@+id/icno_member"
            android:layout_gravity="center"
            android:clickable="false"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:layout_width="@dimen/dp_73"
            android:layout_height="@dimen/dp_73"
            android:src="@mipmap/icon_main_member_not_select" />

    </com.lihang.ShadowLayout>
</RelativeLayout>