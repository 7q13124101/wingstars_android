<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_gravity="top"
        android:gravity="center_horizontal"
        android:padding="11dp"
        android:paddingBottom="@dimen/dp_18"
        android:background="@color/white">

        <!-- Hero card / hình nhóm -->
        <ImageView
            android:id="@+id/imgHero"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:adjustViewBounds="true"
            android:layout_marginTop="10dp"
            android:scaleType="centerCrop"
            android:src="@drawable/img_welcome_hero"/>

        <!-- Logo nhỏ -->
        <ImageView
            android:layout_width="74dp"
            android:layout_height="51dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_logo_small"
            android:contentDescription="@string/app_name"/>

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wings to the Stars"
            android:textColor="@color/text_tittle"
            android:textStyle="bold"
            android:textSize="24sp"
            android:layout_marginTop="30dp"
            android:gravity="center"/>

        <!-- Description -->
        <TextView
            android:id="@+id/tvDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/text_body"
            android:textSize="@dimen/dp_14"
            android:text="相信自己，讓信念化作隱形的翅膀，勇敢追逐夢想，飛向燦爛星空，成為獨一無二、最閃耀的那顆新星。"
            android:gravity="center"/>

        <!-- CTA -->
        <Button
            android:id="@+id/btnStart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/dp_18"
            android:layout_marginTop="67dp"
            android:textSize="@dimen/dp_14"
            android:text="開始使用"
            android:textColor="@color/white"
            android:background="@drawable/bg_button_m"
            android:layout_marginBottom="30pt"/>
    </LinearLayout>
</ScrollView>
