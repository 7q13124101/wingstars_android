<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TopCornersRounded">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">8dp</item>
        <item name="cornerSizeTopRight">8dp</item>
        <item name="cornerSizeBottomLeft">0dp</item>
        <item name="cornerSizeBottomRight">0dp</item>
    </style>

    <style name="CornersRounded">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">16dp</item>
        <item name="cornerSizeTopRight">16dp</item>
        <item name="cornerSizeBottomLeft">16dp</item>
        <item name="cornerSizeBottomRight">16dp</item>
    </style>

    <style name="TabTextStyle" parent="TextAppearance.AppCompat.Body1">
        <item name="android:ellipsize">end</item>
        <item name="android:maxLines">1</item>
    </style>

    <style name="UpLoadingDialog" parent="android:Theme.Dialog">
        //是否去除边框
        <item name="android:windowFrame">@null</item>
        //是否浮在activity上
        <item name="android:windowIsFloating">true</item>
        //窗口是否设置为半透明
        <item name="android:windowIsTranslucent">false</item>
        //是否去除标题
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        //是否模糊（为false 窗口就不会有那种透明的效果了）
        <item name="android:backgroundDimEnabled">false</item>
        //背景颜色及透明度，整个窗口的背景，包扣边框和内部
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>