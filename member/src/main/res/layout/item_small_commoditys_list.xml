<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical">
    <RelativeLayout
        android:id="@+id/item"
        android:layout_marginTop="@dimen/dp_21"
        android:layout_width="@dimen/dp_112"
        android:layout_height="@dimen/dp_44"
        android:background="@mipmap/ic_commodity_background">
        <RelativeLayout
            android:id="@+id/image_layout"
            android:layout_marginLeft="@dimen/dp_14"
            android:layout_centerVertical="true"
            android:layout_width="@dimen/dp_30"
            android:layout_height="@dimen/dp_30"
            android:background="@drawable/ic_white_circle_border">
            <ImageView
                android:scaleType="fitCenter"
                android:id="@+id/image"
                android:layout_centerInParent="true"
                android:layout_width="@dimen/dp_22"
                android:layout_height="@dimen/dp_22"
                android:src="@mipmap/ic_demo3"/>
        </RelativeLayout>
        <TextView
            android:id="@+id/title"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="緞帶蝴蝶結髮飾の曲儿我去玩儿防守打法收到"
            android:textSize="@dimen/sp_12"
            android:textColor="@color/color_4A5565"
            android:layout_marginRight="@dimen/dp_8"
            android:layout_centerVertical="true"
            android:layout_marginLeft="@dimen/dp_6"
            android:layout_toRightOf="@id/image_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </RelativeLayout>
</LinearLayout>