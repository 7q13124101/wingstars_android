<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <com.lihang.ShadowLayout
        android:id="@+id/item"
        android:layout_width="@dimen/dp_176"
        android:layout_height="@dimen/dp_279"
        android:layout_marginRight="@dimen/dp_10"
        app:hl_cornerRadius="@dimen/dp_20"
        app:hl_shadowHidden="false"
        app:hl_strokeColor="@color/color_DE9DBA"
        app:hl_strokeWith="@dimen/dp_1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <FrameLayout
                android:padding="@dimen/dp_1"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_236">
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_girl_introduction_image"/>
                <ImageView
                    android:id="@+id/image"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_236"
                    android:scaleType="fitCenter" />
            </FrameLayout>


            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dp_1"
                android:background="@color/color_DE9DBA" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/tv_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="@dimen/dp_20"
                    android:layout_toLeftOf="@id/nums"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:text="安芝儇"
                    android:textColor="@color/color_101828"
                    android:textSize="@dimen/sp_16"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/nums"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentRight="true"
                    android:layout_centerVertical="true"
                    android:layout_marginRight="@dimen/dp_15"
                    android:ellipsize="end"
                    android:singleLine="true"
                    android:text="2"
                    android:textColor="@color/color_4A5565"
                    android:textSize="@dimen/sp_16" />
            </RelativeLayout>
        </LinearLayout>
    </com.lihang.ShadowLayout>
</LinearLayout>
