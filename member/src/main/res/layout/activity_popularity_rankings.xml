<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/ranking"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_F3F4F6"
    android:orientation="vertical"
    tools:context=".activity.PopularityRankingActivity">

    <com.wingstars.base.view.TitleView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:icon_right="@mipmap/ic_faq"
        app:title="@string/popularity_ranking" />
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/refresh"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">


            <com.lihang.ShadowLayout
                android:id="@+id/sort"
                android:layout_width="@dimen/dp_124"
                android:layout_height="@dimen/dp_32"
                android:layout_marginLeft="@dimen/dp_20"
                android:layout_marginTop="@dimen/dp_20"
                app:hl_cornerRadius="@dimen/dp_50"
                app:hl_shadowHidden="false"
                app:hl_strokeColor="@color/color_E5E7EB"
                app:hl_strokeWith="@dimen/dp_1">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:id="@+id/type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toLeftOf="@id/arrow"
                        android:gravity="center_horizontal"
                        android:text="@string/support_popularity_list"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_14" />

                    <ImageView
                        android:id="@+id/arrow"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:layout_marginRight="@dimen/dp_17"
                        android:src="@mipmap/ic_down_arrow" />
                </RelativeLayout>
            </com.lihang.ShadowLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/dp_20"
                android:layout_marginTop="@dimen/dp_15"
                android:layout_marginRight="@dimen/dp_20"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:layout_weight="17"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:src="@mipmap/ic_popularity_crown_two" />

                    <FrameLayout
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/dp_3"
                        android:layout_width="@dimen/dp_85"
                        android:layout_height="@dimen/dp_85"
                        android:background="@drawable/two_shape_ring">
                        <ImageView
                            android:id="@+id/second"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            />
                    </FrameLayout>


                    <TextView
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:id="@+id/name2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/dp_14"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_16" />

                    <com.lihang.ShadowLayout
                        android:layout_width="@dimen/dp_87"
                        android:layout_height="@dimen/dp_35"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/dp_14"
                        app:hl_cornerRadius="@dimen/dp_50"
                        app:hl_shadowHidden="false">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:src="@mipmap/ic_big_award" />

                            <TextView
                                android:id="@+id/volume2"
                                android:singleLine="true"
                                android:ellipsize="end"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="@dimen/dp_3"
                                android:textColor="@color/color_101828"
                                android:textSize="@dimen/sp_16" />
                        </LinearLayout>
                    </com.lihang.ShadowLayout>
                </LinearLayout>

                <LinearLayout

                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"
                    android:layout_weight="24"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:src="@mipmap/ic_popularity_crown_one" />


                    <FrameLayout
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/dp_3"
                        android:layout_width="@dimen/dp_120"
                        android:layout_height="@dimen/dp_120"
                        android:background="@drawable/one_shape_ring">
                        <ImageView
                            android:layout_gravity="center"
                            android:id="@+id/one"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            />
                    </FrameLayout>


                    <TextView
                        android:id="@+id/name1"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/dp_14"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_16" />


                    <com.lihang.ShadowLayout
                        android:layout_width="87dp"
                        android:layout_height="35dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/dp_14"
                        app:hl_cornerRadius="50dp"
                        app:hl_shadowHidden="false">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:src="@mipmap/ic_big_award" />

                            <TextView
                                android:singleLine="true"
                                android:ellipsize="end"
                                android:id="@+id/volume1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="@dimen/dp_3"
                                android:textColor="@color/color_101828"
                                android:textSize="@dimen/sp_16" />
                        </LinearLayout>
                    </com.lihang.ShadowLayout>
                </LinearLayout>


                <LinearLayout
                    android:layout_width="@dimen/dp_0"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:layout_weight="17"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:src="@mipmap/ic_popularity_crown_three" />

                    <FrameLayout
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/dp_3"
                        android:layout_width="@dimen/dp_85"
                        android:layout_height="@dimen/dp_85"
                        android:background="@drawable/three_shape_ring">
                        <ImageView
                            android:id="@+id/three"
                            android:layout_width="@dimen/dp_85"
                            android:layout_height="@dimen/dp_85"
                            />
                    </FrameLayout>


                    <TextView
                        android:id="@+id/name3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/dp_14"
                        android:singleLine="true"
                        android:ellipsize="end"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_16" />

                    <com.lihang.ShadowLayout
                        android:layout_width="@dimen/dp_87"
                        android:layout_height="@dimen/dp_35"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/dp_14"
                        app:hl_cornerRadius="@dimen/dp_50"
                        app:hl_shadowHidden="false">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:orientation="horizontal">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:src="@mipmap/ic_big_award" />

                            <TextView
                                android:id="@+id/volume3"
                                android:singleLine="true"
                                android:ellipsize="end"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="@dimen/dp_3"
                                android:textColor="@color/color_101828"
                                android:textSize="@dimen/sp_16" />
                        </LinearLayout>
                    </com.lihang.ShadowLayout>
                </LinearLayout>
            </LinearLayout>

            <com.lihang.ShadowLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/dp_30"
                app:hl_cornerRadius_leftTop="@dimen/dp_20"
                app:hl_cornerRadius_rightTop="@dimen/dp_20"
                app:hl_shadowHidden="false">
                <RelativeLayout
                    android:id="@+id/not_data"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:layout_marginTop="@dimen/dp_57"
                        android:layout_centerHorizontal="true"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_gravity="center_horizontal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:src="@mipmap/ic_not_data"/>
                        <TextView
                            android:layout_marginTop="@dimen/dp_16"
                            android:textSize="@dimen/sp_14"
                            android:textColor="@color/color_6A7282"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/no_record"/>
                    </LinearLayout>
                </RelativeLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rank_list"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="@dimen/dp_30"
                    android:layout_marginTop="@dimen/dp_30"
                    android:layout_marginRight="@dimen/dp_30"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
            </com.lihang.ShadowLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
</LinearLayout>