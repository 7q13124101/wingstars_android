<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/dp_20"
        android:fitsSystemWindows="true"
        tools:context=".user.info.MemberInfoActivity">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_42"
            android:paddingLeft="@dimen/dp_20"
            android:paddingRight="@dimen/dp_20"
            android:id="@+id/rl_top"
            app:layout_constraintTop_toTopOf="parent">

            <RelativeLayout
                android:id="@+id/iv_back"
                android:layout_width="@dimen/dp_70"
                android:layout_height="match_parent">
                <ImageView
                    android:clickable="false"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:layout_width="@dimen/dp_22"
                    android:layout_height="@dimen/dp_15"
                    android:src="@drawable/ic_union"
                    android:layout_centerVertical="true"
                    android:layout_alignParentLeft="true"/>
            </RelativeLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_101828"
                android:layout_centerInParent="true"
                android:text="@string/user_edit_m_profile"
                android:textSize="@dimen/sp_16" />

        </RelativeLayout>


        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/rl_top"
            app:layout_constraintBottom_toTopOf="@id/bottom_layout"
            android:background="@color/color_FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="@string/user_select_fav_member"
                    android:textStyle="bold"
                    android:textColor="@color/color_101828"
                    android:layout_marginLeft="@dimen/dp_20"
                    android:textSize="24sp"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_member"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/dp_20"
                    android:scrollbars="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_member_second"
                    android:layout_width="match_parent"
                    android:layout_marginLeft="-70dp"
                    android:layout_height="wrap_content"
                    android:scrollbars="horizontal"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
                <RelativeLayout
                    android:id="@+id/rl_team_member"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_user_form"
                    android:layout_margin="@dimen/dp_20"
                    android:paddingEnd="5dp"
                    android:paddingStart="5dp">

                    <AutoCompleteTextView
                        android:id="@+id/edt_team_member"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="5dp"
                        android:hint="@string/hint_user_first"
                        android:singleLine="true"
                        android:completionThreshold="0"
                        android:dropDownHeight="wrap_content"
                        android:dropDownWidth="wrap_content"
                        android:cursorVisible="true"
                        android:inputType="text"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_toStartOf="@id/iv_arrow_down"
                        android:ellipsize="end"
                        android:textColor="@color/color_99A1AF"
                        android:scrollHorizontally="true"/>

                    <ImageView
                        android:id="@+id/iv_arrow_down"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_arrow_down"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:padding="5dp"/>
                </RelativeLayout>
                <RelativeLayout
                    android:id="@+id/rl_team_member1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_user_form"
                    android:layout_margin="@dimen/dp_20"
                    android:paddingEnd="5dp"
                    android:paddingStart="5dp">

                    <AutoCompleteTextView
                        android:id="@+id/edt_team_member1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="5dp"
                        android:hint="@string/hint_user_second"
                        android:singleLine="true"
                        android:completionThreshold="0"
                        android:dropDownHeight="wrap_content"
                        android:dropDownWidth="wrap_content"
                        android:cursorVisible="true"
                        android:inputType="text"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true"
                        android:ellipsize="end"
                        android:textColor="@color/color_99A1AF"
                        android:scrollHorizontally="true"/>

                    <ImageView
                        android:id="@+id/iv_arrow_down1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_arrow_down"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:padding="5dp"/>
                </RelativeLayout>
                <RelativeLayout
                    android:id="@+id/rl_team_member2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_user_form"
                    android:layout_margin="@dimen/dp_20"
                    android:paddingEnd="5dp"
                    android:paddingStart="5dp">

                    <AutoCompleteTextView
                        android:id="@+id/edt_team_member2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="5dp"
                        android:hint="@string/hint_user_third"
                        android:singleLine="true"
                        android:completionThreshold="0"
                        android:dropDownHeight="wrap_content"
                        android:dropDownWidth="wrap_content"
                        android:cursorVisible="true"
                        android:inputType="text"
                        android:background="@null"
                        android:clickable="true"
                        android:focusable="true"
                        android:ellipsize="end"
                        android:textColor="@color/color_99A1AF"
                        android:scrollHorizontally="true"/>

                    <ImageView
                        android:id="@+id/iv_arrow_down2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/ic_arrow_down"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:padding="5dp"/>
                </RelativeLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>


        <RelativeLayout
            android:id="@+id/bottom_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="@color/color_F3F4F6">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:textSize="@dimen/sp_14"
                android:paddingTop="@dimen/pt_14"
                android:paddingBottom="@dimen/pt_14"
                android:text="@string/user_save"
                android:gravity="center"
                android:textColor="@color/color_6A7282"
                android:background="@color/color_E5E7EB" />

        </RelativeLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
