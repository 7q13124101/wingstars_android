<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/dp_20"
        android:fitsSystemWindows="true"
        tools:context=".user.info.MemberInfoActivity">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_42"
            android:paddingLeft="@dimen/dp_20"
            android:paddingRight="@dimen/dp_20"
            android:id="@+id/rl_top"
            app:layout_constraintTop_toTopOf="parent">

            <RelativeLayout
                android:id="@+id/iv_back"
                android:layout_width="@dimen/dp_70"
                android:layout_height="match_parent">
                <ImageView
                    android:clickable="false"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:layout_width="@dimen/dp_22"
                    android:layout_height="@dimen/dp_15"
                    android:src="@drawable/ic_union"
                    android:layout_centerVertical="true"
                    android:layout_alignParentLeft="true"/>
            </RelativeLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_101828"
                android:layout_centerInParent="true"
                android:text="@string/user_change_password"
                android:textSize="@dimen/sp_16" />

        </RelativeLayout>


        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/rl_top"
            app:layout_constraintBottom_toTopOf="@id/bottom_layout"
            android:background="@color/color_FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingLeft="@dimen/dp_20"
                    android:paddingRight="@dimen/dp_20"
                    android:layout_marginTop="@dimen/dp_10">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/password"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_24" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/enter_your_new_pass"
                        android:textColor="@color/color_6A7282"
                        android:textSize="@dimen/sp_14"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_15"
                        android:text="@string/old_password"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_14" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_8"
                        android:addStatesFromChildren="true"
                        android:background="@drawable/bg_change_password"
                        android:paddingLeft="@dimen/dp_20"
                        android:paddingTop="@dimen/dp_17"
                        android:paddingRight="@dimen/dp_20"
                        android:paddingBottom="@dimen/dp_17">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/edt_old_code"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="請輸入您目前使用的密碼"
                            android:imeOptions="actionNext"
                            android:inputType="textPassword"
                            android:nextFocusForward="@id/edt_new_code"
                            android:singleLine="true"
                            android:textColor="@color/color_101828"
                            android:textColorHint="@color/color_99A1AF"
                            android:textSize="@dimen/sp_16" />
                    </RelativeLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_15"
                        android:text="@string/new_password"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_14" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_8"
                        android:addStatesFromChildren="true"
                        android:background="@drawable/bg_change_password"
                        android:paddingLeft="@dimen/dp_20"
                        android:paddingTop="@dimen/dp_17"
                        android:paddingRight="@dimen/dp_20"
                        android:paddingBottom="@dimen/dp_17">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/edt_new_code"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="請輸入新密碼"
                            android:imeOptions="actionNext"
                            android:inputType="textPassword"
                            android:nextFocusForward="@id/edt_new_confirm"
                            android:singleLine="true"
                            android:textColor="@color/color_101828"
                            android:textColorHint="@color/color_99A1AF"
                            android:textSize="@dimen/sp_16" />
                    </RelativeLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_15"
                        android:text="@string/new_pass_confirm"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_14" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_8"
                        android:addStatesFromChildren="true"
                        android:background="@drawable/bg_change_password"
                        android:paddingLeft="@dimen/dp_20"
                        android:paddingTop="@dimen/dp_17"
                        android:paddingRight="@dimen/dp_20"
                        android:paddingBottom="@dimen/dp_17">

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/edt_new_confirm"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="請再次輸入相同密碼"
                            android:imeOptions="actionNext"
                            android:inputType="textPassword"
                            android:nextFocusForward="@id/btn_send_code"
                            android:singleLine="true"
                            android:textColor="@color/color_101828"
                            android:textColorHint="@color/color_99A1AF"
                            android:textSize="@dimen/sp_16" />
                    </RelativeLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_15"
                        android:text="@string/enter_confirmation_code"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_14" />
                    <RelativeLayout
                        android:id="@+id/rl_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_8"
                        android:addStatesFromChildren="true"
                        android:background="@drawable/bg_change_password"
                        android:paddingStart="@dimen/dp_20"
                        android:paddingTop="@dimen/dp_17"
                        android:paddingEnd="@dimen/dp_20"
                        android:paddingBottom="@dimen/dp_17">

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btn_send_code"
                            android:layout_width="wrap_content"
                            android:layout_height="25dp"
                            android:minWidth="80dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_send_code"
                            android:paddingStart="@dimen/dp_12"
                            android:paddingEnd="@dimen/dp_12"
                            android:text="@string/send_phone_code"
                            android:textAlignment="center"
                            android:textColor="@color/white"
                            android:textSize="@dimen/sp_16"
                            android:visibility="visible" />
                        <LinearLayout
                            android:id="@+id/ll_countdown"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:visibility="gone"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true">

                            <TextView
                                android:id="@+id/tv_seconds"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/color_EE97BB"
                                android:textSize="@dimen/sp_16"
                                android:text="60" />

                            <TextView
                                android:id="@+id/tv_resend"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/color_101828"
                                android:text="重新傳送"
                                android:textSize="@dimen/sp_16"
                                android:layout_marginStart="4dp" />

                        </LinearLayout>

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/edt_phone"
                            android:layout_width="@dimen/dp_150"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:background="@null"
                            android:hint="請輸入驗證碼"
                            android:imeOptions="actionNext"
                            android:inputType="phone"
                            android:singleLine="true"
                            android:textColor="@color/color_101828"
                            android:textColorHint="@color/color_99A1AF"
                            android:textSize="@dimen/sp_16" />
                    </RelativeLayout>


                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
        <RelativeLayout
            android:id="@+id/bottom_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="@color/color_F3F4F6">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_save"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:enabled="false"
                android:textSize="@dimen/sp_14"
                android:paddingTop="@dimen/pt_14"
                android:paddingBottom="@dimen/pt_14"
                android:text="@string/user_save"
                android:gravity="center"
                android:textColor="@color/black"
                android:background="@color/color_F3F4F6" />

        </RelativeLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
