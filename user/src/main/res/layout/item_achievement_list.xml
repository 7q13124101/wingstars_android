<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/pt_30"
        android:orientation="vertical">

        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:id="@+id/ll_achievement"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center">

            <ImageView
                android:id="@+id/iv_achievement_icon"
                android:layout_width="@dimen/pt_98"
                android:layout_height="@dimen/pt_98"
                android:layout_gravity="center" />
        </LinearLayout>

        <TextView
            android:singleLine="true"
            android:ellipsize="end"
            android:id="@+id/tv_achievement_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pt_12"
            android:gravity="center_horizontal"
            android:textColor="@color/color_101828"
            android:textSize="@dimen/sp_14"
            android:textStyle="bold" />

        <TextView
            android:visibility="gone"
            android:ellipsize="end"
            android:id="@+id/tv_achievement_condition"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="@dimen/pt_12"
            android:gravity="center"
            android:singleLine="true"
            android:text="APP 首次簽到"
            android:textColor="@color/color_101828"
            android:textSize="@dimen/sp_14" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pt_12">

            <TextView
                android:ellipsize="end"
                android:singleLine="true"
                android:id="@+id/tv_achievement_number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:textColor="@color/color_101828"
                android:textSize="@dimen/sp_14"/>

            <RelativeLayout
                android:id="@+id/rl_progress_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:visibility="invisible">

<!--                <ProgressBar-->
<!--                    android:id="@+id/pb_circularProgressBar"-->
<!--                    style="?android:attr/progressBarStyleHorizontal"-->
<!--                    android:layout_width="@dimen/pt_98"-->
<!--                    android:layout_height="@dimen/pt_20"-->
<!--                    android:layout_centerInParent="true"-->
<!--                    android:indeterminate="false"-->
<!--                    android:progressDrawable="@drawable/progress_progress"-->
<!--                    android:background="@drawable/progress_background" />-->

<!--                <TextView-->
<!--                    android:id="@+id/tv_ViewProgress"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:layout_centerInParent="true"-->
<!--                    android:text=""-->
<!--                    android:textColor="@color/color_737373"-->
<!--                    android:textSize="@dimen/sp_14" />-->
            </RelativeLayout>
        </RelativeLayout>
    </LinearLayout>

</layout>