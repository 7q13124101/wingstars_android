<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dialog_bottom"
        android:orientation="vertical"
        android:paddingStart="@dimen/dp_20"
        android:paddingTop="@dimen/dp_15"
        android:paddingEnd="@dimen/dp_20"
        android:paddingBottom="@dimen/dp_32">

        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="@dimen/dp_24"
            android:layout_height="@dimen/dp_24"
            android:src="@drawable/ic_cancel"
            android:layout_gravity="end"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_cheer"
            android:textColor="@color/color_101828"
            android:textStyle="bold"
            android:textSize="@dimen/sp_16" />

        <RelativeLayout
            android:id="@+id/rl_hurrays_phrases"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_20"
            android:background="@drawable/bg_list_search_background"
            android:paddingStart="@dimen/dp_8"
            android:paddingTop="@dimen/dp_16"
            android:paddingEnd="@dimen/dp_4"
            android:paddingBottom="@dimen/dp_16">

            <EditText
                android:id="@+id/edt_hurrays_phrases"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:drawableEnd="@drawable/ic_clear"
                android:hint="@string/hint_type_text"
                android:imeOptions="actionDone"
                android:maxLength="1000"
                android:singleLine="true"
                android:textColor="@color/color_101828"
                android:textSize="@dimen/sp_14" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/rl_team_member"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_outline_rounded"
            android:layout_marginTop="@dimen/dp_20"
            android:paddingStart="@dimen/dp_8"
            android:paddingEnd="@dimen/dp_4"
            android:paddingTop="@dimen/dp_16"
            android:paddingBottom="@dimen/dp_16">

            <AutoCompleteTextView
                android:id="@+id/edt_team_member"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_type_text1"
                android:singleLine="true"
                android:drawableEnd="@drawable/ic_chevron_down"
                android:focusable="false"
                android:textSize="@dimen/sp_14"
                android:cursorVisible="false"
                android:clickable="true"
                android:inputType="none"
                android:background="@null"/>
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/dp_5">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cheer_font_size"
                android:textColor="@color/color_101828"
                android:textStyle="bold"
                android:textSize="@dimen/sp_14"
                android:layout_marginTop="@dimen/dp_20"
                android:layout_marginBottom="@dimen/dp_16"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_font_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3"
                tools:listitem="@layout/item_select_phrase"
                tools:itemCount="3"/>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_20"
                android:text="@string/cheer_play_speed"
                android:textColor="@color/color_101828"
                android:textStyle="bold"
                android:textSize="@dimen/sp_14"
                android:layout_marginBottom="@dimen/dp_16"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_play_speed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3"
                tools:listitem="@layout/item_select_phrase"
                tools:itemCount="3"/>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_20"
                android:text="@string/color"
                android:textColor="@color/color_101828"
                android:textStyle="bold"
                android:textSize="@dimen/sp_14"
                android:layout_marginBottom="@dimen/dp_16"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/ll_font_color"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingVertical="@dimen/dp_15"
                    android:background="@drawable/bg_outline_rounded"
                    android:layout_marginEnd="@dimen/dp_8">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/font"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_14"
                        android:textStyle="bold"/>

                    <View
                        android:id="@+id/view_font_color_indicator"
                        android:layout_width="@dimen/dp_20"
                        android:layout_height="@dimen/dp_20"
                        android:layout_marginStart="@dimen/dp_8"
                        android:background="@drawable/shape_circle_black" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_bg_color"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:paddingVertical="@dimen/dp_15"
                    android:background="@drawable/bg_outline_rounded"
                    android:layout_marginStart="@dimen/dp_8">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/background"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_14"
                        android:textStyle="bold"/>

                    <View
                        android:id="@+id/view_bg_color_indicator"
                        android:layout_width="@dimen/dp_20"
                        android:layout_height="@dimen/dp_20"
                        android:layout_marginStart="@dimen/dp_8"
                        android:background="@drawable/shape_circle_pink" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</layout>
