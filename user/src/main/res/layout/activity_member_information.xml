<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/dp_20"
        android:fitsSystemWindows="true"
        android:background="@color/white"
        tools:context=".user.info.MemberInfoActivity">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_42"
            android:paddingLeft="@dimen/dp_20"
            android:paddingRight="@dimen/dp_20"
            android:id="@+id/rl_top"
            app:layout_constraintTop_toTopOf="parent">

            <RelativeLayout
                android:id="@+id/iv_back"
                android:layout_width="@dimen/dp_70"
                android:layout_height="match_parent">
                <ImageView
                    android:clickable="false"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:layout_width="@dimen/dp_22"
                    android:layout_height="@dimen/dp_15"
                    android:src="@drawable/ic_union"
                    android:layout_centerVertical="true"
                    android:layout_alignParentLeft="true"/>
            </RelativeLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_101828"
                android:layout_centerInParent="true"
                android:text="@string/user_member_information"
                android:textSize="@dimen/sp_16" />

        </RelativeLayout>


        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/rl_top">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    android:gravity="center_vertical"
                    android:paddingLeft="@dimen/dp_24"
                    android:paddingRight="@dimen/dp_24"
                    android:paddingTop="@dimen/dp_16"
                    android:paddingBottom="@dimen/dp_16">

                    <ImageView
                        android:id="@+id/iv_icon"
                        android:layout_width="88dp"
                        android:layout_height="88dp"
                        android:src="@drawable/ic_icon"
                        android:layout_alignParentLeft="true"
                        android:layout_centerVertical="true" />
                    <LinearLayout
                        android:id="@+id/ll_user_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_centerVertical="true"
                        android:layout_toRightOf="@id/iv_icon"
                        android:layout_toLeftOf="@id/container_for_rectangle_and_text"
                        android:layout_marginLeft="12dp"
                        android:layout_marginRight="12dp">

                        <TextView
                            android:id="@+id/tv_user_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="陳美莉"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_101828"/>

                        <TextView
                            android:id="@+id/tv_user_mail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="newsoft@gmail.com"
                            android:textSize="14sp"
                            android:textColor="@color/color_6A7282"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/diamond"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dp_172"
                    android:layout_margin="@dimen/dp_20"
                    android:elevation="2dp"
                    android:background="@drawable/bg_user_info">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        tools:ignore="MissingConstraints">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="@dimen/dp_10"
                            android:layout_marginLeft="@dimen/dp_20">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/user_phone_number"
                                android:textColor="@color/color_6A7282"
                                android:textSize="@dimen/sp_14"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0900000001"
                                android:textColor="@color/color_101828"
                                android:layout_marginRight="@dimen/dp_20"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="@dimen/dp_15"
                            android:layout_marginLeft="@dimen/dp_20">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/user_id_number"
                                android:textColor="@color/color_6A7282"
                                android:textSize="@dimen/sp_14"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="A123456789"
                                android:textColor="@color/color_101828"
                                android:layout_marginRight="@dimen/dp_20"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="@dimen/dp_15"
                            android:layout_marginLeft="@dimen/dp_20">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/user_birthday"
                                android:textColor="@color/color_6A7282"
                                android:textSize="@dimen/sp_14"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1986/01/01"
                                android:textColor="@color/color_101828"
                                android:layout_marginRight="@dimen/dp_20"/>
                        </LinearLayout>


                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="@dimen/dp_15"
                            android:layout_marginLeft="@dimen/dp_20">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/user_gender"
                                android:textColor="@color/color_6A7282"
                                android:textSize="@dimen/sp_14"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginRight="@dimen/dp_20"
                                android:textColor="@color/color_101828"
                                android:text="女性" />
                        </LinearLayout>

                    </LinearLayout>


                </androidx.constraintlayout.widget.ConstraintLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingLeft="@dimen/dp_24"
                    android:paddingRight="@dimen/dp_24"
                    android:paddingBottom="@dimen/dp_20"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_20"
                        android:text="@string/user_fav_member"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_14" />

                    <LinearLayout
                        android:id="@+id/f_fav_member"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/dp_8">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/edt_fav_member"
                                android:layout_width="@dimen/dp_64"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="@string/user_n_entered_yet"
                                android:singleLine="true"
                                android:layout_weight="1"
                                android:textColor="@color/color_101828"
                                android:textColorHint="@color/color_99A1AF"
                                android:textSize="@dimen/sp_16" />
                            <ImageView
                                android:layout_width="@dimen/dp_24"
                                android:layout_height="@dimen/dp_24"
                                android:src="@drawable/ic_arrow_right"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/color_D1D5DC" />
                    </LinearLayout>
<!--                    android:nextFocusForward="@id/edt_phone_code"-->

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_20"
                        android:text="@string/user_tsg_phone_code"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_14" />

                    <LinearLayout
                        android:id="@+id/f_barcode_carrier"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/dp_8">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/edt_barcode_carrier"
                                android:layout_width="@dimen/dp_64"
                                android:layout_height="wrap_content"
                                android:background="@null"
                                android:hint="@string/user_n_entered_yet"
                                android:singleLine="true"
                                android:layout_weight="1"
                                android:textColor="@color/color_101828"
                                android:textColorHint="@color/color_99A1AF"
                                android:textSize="@dimen/sp_16" />
                            <ImageView
                                android:layout_width="@dimen/dp_24"
                                android:layout_height="@dimen/dp_24"
                                android:src="@drawable/ic_arrow_right"/>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/color_D1D5DC" />
                    </LinearLayout>


                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_20"
                        android:text="@string/user_password"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_14" />

                    <LinearLayout
                        android:id="@+id/ll_edt_id_card"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/dp_8">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <androidx.appcompat.widget.AppCompatEditText
                                android:id="@+id/edt_id_card"
                                android:layout_width="@dimen/dp_64"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="@null"
                                android:text="********"
                                android:singleLine="true"
                                android:textColor="@color/color_101828"
                                android:textColorHint="@color/color_A3A3A3"
                                android:textSize="@dimen/sp_14"
                                android:focusable="false"
                                android:clickable="true"/>
                            <ImageView
                                android:id="@+id/iv_id_card"
                                android:layout_width="@dimen/dp_24"
                                android:layout_height="@dimen/dp_24"
                                android:src="@drawable/ic_arrow_right"
                                android:layout_marginStart="@dimen/dp_6"
                                android:focusable="false"
                                android:cursorVisible="false"
                                android:inputType="none"
                                android:clickable="true"/>
                        </LinearLayout>


                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="@color/color_D1D5DC" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_20"
                        android:text="@string/user_member_account"
                        android:textColor="@color/color_101828"
                        android:textSize="@dimen/sp_14" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/edt_member_account"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="@string/user_per_d_m_account"
                            android:singleLine="true"
                            android:textColor="@color/color_101828"
                            android:textColorHint="@color/color_99A1AF"
                            android:textSize="@dimen/sp_16" />
                        <TextView
                            android:id="@+id/edt_delete_account"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/user_delete_account"
                            android:textSize="@dimen/sp_16"
                            android:layout_marginLeft="@dimen/dp_100"
                            android:textColor="@color/color_E2518D"/>
                    </LinearLayout>


                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/color_D1D5DC" />
                </LinearLayout>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>


<!--        <androidx.appcompat.widget.AppCompatButton-->
<!--            android:id="@+id/btn_save"-->
<!--            android:layout_width="match_parent"-->
<!--            android:layout_height="wrap_content"-->
<!--            app:layout_constraintBottom_toBottomOf="parent"-->
<!--            android:enabled="false"-->
<!--            android:textSize="@dimen/sp_14"-->
<!--            android:paddingTop="@dimen/pt_14"-->
<!--            android:paddingBottom="@dimen/pt_14"-->
<!--            android:text="@string/user_save"-->
<!--            android:gravity="center"-->
<!--            android:textColor="@color/white"-->
<!--            android:background="@color/color_DE9DBA"/>-->

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
