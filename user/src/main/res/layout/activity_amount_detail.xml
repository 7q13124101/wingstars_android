<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".activity.CumulativeAmountActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_F5F5F5"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/top_container"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <RelativeLayout
                android:id="@+id/rl_top"
                android:layout_width="match_parent"
                android:layout_height="@dimen/pt_30">

                <RelativeLayout
                    android:id="@+id/img_back"
                    android:layout_width="@dimen/pt_70"
                    android:layout_height="match_parent">

                    <ImageView
                        android:layout_width="@dimen/pt_15"
                        android:layout_height="@dimen/pt_15"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="@dimen/pt_10"
                        android:clickable="false"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:src="@drawable/ic_back_black" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="@string/user_cumulative_amount"
                    android:textColor="@color/color_101828"
                    android:textSize="@dimen/sp_16"
                    android:textStyle="bold"/>
            </RelativeLayout>

        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:padding="@dimen/pt_7">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_user_ractangle"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/tv_order_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="訂單編號 : 43610"
                    android:textColor="#5F6A78"
                    android:textSize="@dimen/sp_14"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="20dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_products"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintTop_toBottomOf="@+id/tv_order_number"
                    tools:listitem="@layout/item_order_list"
                    tools:itemCount="4"/>

                <View
                    android:id="@+id/divider_footer"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E5E7EB"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintTop_toBottomOf="@+id/rv_products" />

                <TextView
                    android:id="@+id/label_subtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="小計"
                    android:textColor="#4A5565"
                    android:textSize="@dimen/sp_16"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="16dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/divider_footer" />

                <TextView
                    android:id="@+id/tv_subtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$3,800"
                    android:textColor="#101828"
                    android:textSize="@dimen/sp_16"
                    android:textStyle="bold"
                    android:layout_marginEnd="16dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintBaseline_toBaselineOf="@+id/label_subtotal"/>

                <TextView
                    android:id="@+id/label_points"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="獲得點數"
                    android:textColor="#E91E63"
                    android:textSize="@dimen/sp_16"
                    android:layout_marginTop="12dp"
                    app:layout_constraintStart_toStartOf="@+id/label_subtotal"
                    app:layout_constraintTop_toBottomOf="@+id/label_subtotal" />

                <TextView
                    android:id="@+id/tv_points"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="30"
                    android:textColor="#E91E63"
                    android:textSize="@dimen/sp_16"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="@+id/tv_subtotal"
                    app:layout_constraintBaseline_toBaselineOf="@+id/label_points"/>

                <TextView
                    android:id="@+id/label_shipping"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="運費"
                    android:textColor="#4A5565"
                    android:textSize="@dimen/sp_16"
                    android:layout_marginTop="12dp"
                    app:layout_constraintStart_toStartOf="@+id/label_subtotal"
                    app:layout_constraintTop_toBottomOf="@+id/label_points" />

                <TextView
                    android:id="@+id/tv_shipping"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$100"
                    android:textColor="#101828"
                    android:textSize="@dimen/sp_16"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="@+id/tv_subtotal"
                    app:layout_constraintBaseline_toBaselineOf="@+id/label_shipping"/>

                <TextView
                    android:id="@+id/label_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="總金額"
                    android:textColor="#4A5565"
                    android:textSize="@dimen/sp_16"
                    android:layout_marginTop="12dp"
                    app:layout_constraintStart_toStartOf="@+id/label_subtotal"
                    app:layout_constraintTop_toBottomOf="@+id/label_shipping" />

                <TextView
                    android:id="@+id/tv_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$3,900"
                    android:textColor="#101828"
                    android:textSize="@dimen/sp_16"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="@+id/tv_subtotal"
                    app:layout_constraintBaseline_toBaselineOf="@+id/label_total"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>

</layout>