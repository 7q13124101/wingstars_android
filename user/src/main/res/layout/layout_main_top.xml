<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rl_top"
    android:layout_width="@dimen/dp_402"
    android:layout_height="@dimen/dp_64"
    android:paddingLeft="@dimen/dp_20"
    android:paddingRight="@dimen/dp_20">
    <ImageView
        android:id="@+id/iv_icon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_icon"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true" />
        <FrameLayout
            android:id="@+id/container_for_rectangle_and_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:background="@drawable/bg_rectangle_white"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true">
            <TextView
                android:id="@+id/tv_on_rectangle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@android:color/black"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_login_logout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="登入/註冊"
                android:textColor="@android:color/black"
                android:textSize="14sp"
                android:textStyle="bold" />
        </FrameLayout>

    <LinearLayout
        android:id="@+id/ll_user_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_centerVertical="true"
        android:layout_toRightOf="@id/iv_icon"
        android:layout_toLeftOf="@id/container_for_rectangle_and_text"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp">

        <TextView
            android:id="@+id/tv_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/user_main_visitors"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="一般訪客"
            android:textSize="12sp"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

    </RelativeLayout>