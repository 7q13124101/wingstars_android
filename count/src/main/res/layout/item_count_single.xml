<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/pt_16"
        android:background="@drawable/bg_item_hot_product"
        android:orientation="horizontal"
        android:padding="@dimen/pt_7"
        android:layout_margin="@dimen/pt_6"
        android:elevation="@dimen/dp_3">

        <ImageView
            android:id="@+id/iv_arrow_left"
            android:layout_width="@dimen/pt_24"
            android:layout_height="@dimen/pt_24"
            android:scaleType="centerInside"
            android:adjustViewBounds="true"
            android:layout_marginRight="@dimen/pt_5"
            android:src="@drawable/ic_count_im" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="vertical">

        <RelativeLayout
            android:layout_marginBottom="@dimen/pt_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tv_title"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold"
                android:textColor="@color/color_101828"
                android:text="打擊爆發"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

<!--            <ImageView-->
<!--                android:layout_centerVertical="true"-->
<!--                android:layout_alignParentRight="true"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:src="@mipmap/ic_member_back"/>-->
        </RelativeLayout>

        <TextView
            android:id="@+id/tv_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginBottom="@dimen/pt_4"
            android:maxLines="2"
            android:text="當日賽事台鋼獵鷹安打總數達 15 支以上"
            android:textColor="@color/color_4A5565"
            android:textSize="@dimen/sp_14" />

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical"
                android:layout_marginBottom="@dimen/pt_4"
                android:maxLines="2"
                android:text="2025年4月2日 ～ 2025年12月31日"
                android:textColor="@color/color_4A5565"
                android:textSize="@dimen/sp_14" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/rl_icon"
                android:layout_width="@dimen/pt_15"
                android:layout_height="@dimen/pt_15"
                android:scaleType="centerInside"
                android:adjustViewBounds="true"
                android:layout_gravity="center"
                android:src="@drawable/bg_count_deep" />

            <View
                android:layout_width="@dimen/pt_3"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/tv_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="3 點"
                android:textColor="@color/color_4A5565"
                android:textSize="@dimen/sp_18"
                android:textStyle="bold" />

        </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
</layout>