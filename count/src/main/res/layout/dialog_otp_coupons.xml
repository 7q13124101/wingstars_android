<?xml version="1.0" encoding="utf-8"?>
<layout>

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/cl_add_person"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:background="@drawable/bg_custom_dialog">

        <TextView
            android:id="@+id/tv_otp_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_E2518D"
            android:gravity="center"
            android:paddingVertical="6dp"
            android:paddingHorizontal="12dp"
            android:text="436270"
            android:background="@drawable/bg_otp_code"
            android:textStyle="bold|italic"
            android:layout_gravity="center"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp"/>


        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/sp_20"
            android:textColor="@color/color_101828"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/pt_20"
            android:layout_marginLeft="@dimen/pt_16"
            android:layout_marginRight="@dimen/pt_16"/>


        <TextView
            android:id="@+id/content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_6A7282"
            android:layout_marginTop="@dimen/pt_8"
            android:layout_marginLeft="@dimen/pt_16"
            android:layout_marginRight="@dimen/pt_16"/>

        <EditText
            android:id="@+id/et_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLength="6"
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_6A7282"
            android:hint="@string/et_otp"
            android:visibility="gone"
            android:background="@drawable/bg_edittext_otp"
            android:layout_marginTop="@dimen/pt_8"
            android:layout_marginLeft="@dimen/pt_16"
            android:layout_marginRight="@dimen/pt_16"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.8dp"
            android:background="@color/color_A3A3A3"
            android:layout_marginTop="@dimen/pt_17"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tv_no"
                android:layout_width="@dimen/pt_0"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textSize="@dimen/sp_16"
                android:textColor="@color/color_6A7282"
                android:gravity="center"
                android:textStyle="bold"
                android:layout_marginTop="@dimen/pt_14"
                android:layout_marginBottom="@dimen/pt_14" />
            <View
                android:id="@+id/view_middle"
                android:layout_width="0.8dp"
                android:layout_height="match_parent"
                android:background="@color/color_A3A3A3" />
            <TextView
                android:id="@+id/tv_yes"
                android:layout_width="@dimen/pt_0"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:textSize="@dimen/sp_16"
                android:textColor="@color/color_E2518D"
                android:gravity="center"
                android:textStyle="bold"
                android:layout_marginTop="@dimen/pt_14"
                android:layout_marginBottom="@dimen/pt_14" />

        </LinearLayout>

    </LinearLayout>


</layout>
