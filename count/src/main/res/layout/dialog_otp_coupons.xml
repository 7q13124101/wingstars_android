<?xml version="1.0" encoding="utf-8"?>
<layout>
    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:id="@+id/cl_add_person"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_custom_dialog">

        <ImageView
            android:id="@+id/iv_close_dialog"
            android:layout_width="@dimen/pt_24"
            android:layout_height="@dimen/pt_24"
            android:src="@drawable/ic_cancel"
            android:padding="4dp"
            android:layout_marginTop="@dimen/pt_5"
            android:layout_gravity="end"/>

        <TextView
            android:id="@+id/tv_otp_code"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_E2518D"
            android:paddingVertical="6dp"
            android:paddingHorizontal="12dp"
            android:text="436270"
            android:background="@drawable/bg_otp_code"
            android:textStyle="bold|italic"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp"
            android:layout_marginLeft="@dimen/pt_16"/>

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/sp_20"
            android:textColor="@color/color_101828"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/pt_20"
            android:layout_marginLeft="@dimen/pt_16"
            android:layout_marginRight="@dimen/pt_16"/>


        <TextView
            android:id="@+id/content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_101828"
            android:layout_marginTop="@dimen/pt_8"
            android:layout_marginLeft="@dimen/pt_16"
            android:layout_marginRight="@dimen/pt_16"/>

        <EditText
            android:id="@+id/et_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLength="6"
            android:textSize="@dimen/sp_14"
            android:textColor="@color/color_6A7282"
            android:visibility="gone"
            android:background="@drawable/bg_edittext_otp"
            android:padding="12dp"
            android:layout_marginTop="@dimen/pt_8"
            android:layout_marginLeft="@dimen/pt_16"
            android:layout_marginRight="@dimen/pt_16"/>

