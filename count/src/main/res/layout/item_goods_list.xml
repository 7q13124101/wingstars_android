<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/pt_7">

        <com.lihang.ShadowLayout
            android:id="@+id/ll_wing_stars_root"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:hl_cornerRadius="@dimen/dp_12"
            app:hl_shadowColor="@color/color_19000000">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/pt_10">

                <ImageView
                    android:id="@+id/image"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    android:adjustViewBounds="true"
                    android:background="@drawable/bg_round_image"
                    android:clipToOutline="true"
                    android:layout_marginVertical="@dimen/pt_4"
                    />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/pt_12"
                    android:layout_marginEnd="-15dp">

                    <TextView
                        android:id="@+id/coupon_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="有鷹來同樂 TSG Party -  Wing Stars 簽名會（第三梯次）"
                        android:gravity="center_vertical"
                        android:textSize="@dimen/sp_14"
                        android:textStyle="bold"
                        android:textColor="@color/color_101828"
                        android:layout_marginTop="@dimen/pt_6" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/rl_icon"
                            android:layout_width="@dimen/pt_15"
                            android:layout_height="@dimen/pt_15"
                            android:scaleType="centerInside"
                            android:adjustViewBounds="true"
                            android:layout_gravity="center"
                            android:src="@drawable/bg_count_deep" />

                        <View
                            android:layout_width="@dimen/pt_3"
                            android:layout_height="match_parent" />

                        <TextView
                            android:id="@+id/tv_count"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="100"
                            android:textColor="@color/color_4A5565"
                            android:textSize="@dimen/sp_14" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/coupon_start_date"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2025/11/09 (日)"
                        android:textSize="@dimen/sp_14"
                        android:textColor="@color/color_101828" />
                </LinearLayout>

            </LinearLayout>
            <FrameLayout
                android:id="@+id/label"
                android:layout_width="80dp"
                android:layout_height="72dp"
                android:layout_gravity="top|end"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_corner_badge_yellow"
                    android:scaleType="fitXY" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="@dimen/dp_20"
                    android:layout_marginRight="@dimen/pt_3">

                    <TextView
                        android:id="@+id/label_tv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="星朋友"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:includeFontPadding="false"
                        android:lineSpacingExtra="0dp"
                        android:lineSpacingMultiplier="0.9"
                        android:layout_gravity="top|end"
                        android:gravity="center"
                        android:paddingTop="4dp"/>
                </FrameLayout>

            </FrameLayout>

        </com.lihang.ShadowLayout>

    </FrameLayout>
</layout>
