<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <com.lihang.ShadowLayout
        android:id="@+id/ll_wing_stars_root"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/pt_7"
        app:hl_cornerRadius="@dimen/dp_12"
        app:hl_shadowColor="@color/color_19000000">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="@dimen/pt_10"> <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/image"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginStart="@dimen/pt_10"
            android:layout_marginTop="14dp"
            android:scaleType="centerCrop"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CornersRounded_12" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/iv_mask_image"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:src="@color/half_black"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="@id/image"
                app:layout_constraintEnd_toEndOf="@id/image"
                app:layout_constraintStart_toStartOf="@id/image"
                app:layout_constraintTop_toTopOf="@id/image"
                app:shapeAppearanceOverlay="@style/CornersRounded_12" />

            <TextView
                android:id="@+id/tv_exchange_completed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="兌換完畢"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="@id/image"
                app:layout_constraintEnd_toEndOf="@id/image"
                app:layout_constraintStart_toStartOf="@id/image"
                app:layout_constraintTop_toTopOf="@id/image" />


            <TextView
                android:id="@+id/coupon_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/pt_12"
                android:layout_marginTop="@dimen/pt_10"
                android:layout_marginEnd="15dp"
                android:text="有鷹來同樂 TSG Party - Wing Stars 簽名會（第三梯次）"
                android:textColor="@color/color_101828"
                android:textSize="@dimen/sp_14"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/image"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageView
                android:id="@+id/rl_icon"
                android:layout_width="@dimen/pt_15"
                android:layout_height="@dimen/pt_15"
                android:layout_marginTop="@dimen/pt_6"
                android:adjustViewBounds="true"
                android:scaleType="centerInside"
                android:src="@drawable/bg_count_deep"
                app:layout_constraintStart_toStartOf="@id/coupon_name"
                app:layout_constraintTop_toBottomOf="@id/coupon_name" />

            <TextView
                android:id="@+id/tv_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/pt_3"
                android:text="100"
                android:textColor="@color/color_4A5565"
                android:textSize="@dimen/sp_14"
                app:layout_constraintBottom_toBottomOf="@id/rl_icon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/rl_icon"
                app:layout_constraintTop_toTopOf="@id/rl_icon" />

            <TextView
                android:id="@+id/coupon_start_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pt_6"
                android:text="2025/11/09 (日)"
                android:textColor="@color/color_101828"
                android:textSize="@dimen/sp_14"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@id/coupon_name"
                app:layout_constraintTop_toBottomOf="@id/tv_count" />


            <ImageView
                android:id="@+id/iv_badge_bg"
                android:layout_width="wrap_content"
                android:layout_height="72dp"
                android:scaleType="fitXY"
                android:src="@drawable/ic_corner_badge_yellow"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/label_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="@dimen/pt_7"
                android:includeFontPadding="false"
                android:lineSpacingExtra="0dp"
                android:lineSpacingMultiplier="0.9"
                android:text="星朋友"
                android:textColor="@android:color/white"
                android:textSize="@dimen/sp_12"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/iv_badge_bg"
                app:layout_constraintTop_toTopOf="@id/iv_badge_bg" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.lihang.ShadowLayout>
</layout>