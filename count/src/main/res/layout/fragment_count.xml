<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.wingstars.count.fragment.CountFragment">

   <androidx.core.widget.NestedScrollView
       android:id="@+id/fl_top"
       android:layout_width="match_parent"
       android:layout_height="match_parent"
       android:fillViewport="true">
      <LinearLayout
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="vertical"
          android:background="@color/white"
          android:paddingBottom="@dimen/pt_40"
          android:clipToPadding="false">
         <FrameLayout
             android:layout_width="match_parent"
             android:layout_height="wrap_content">
            <ImageView
                android:scaleType="centerCrop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:src="@mipmap/ic_member_page_background"/>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
               <RelativeLayout
                   android:id="@+id/title"
                   android:layout_width="match_parent"
                   android:layout_height="@dimen/dp_64">
                  <LinearLayout
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:layout_centerVertical="true">

                  <TextView
                      android:layout_marginLeft="@dimen/dp_20"
                      android:textColor="@color/color_101828"
                      android:textSize="@dimen/sp_16"
                      android:layout_width="0dp"
                      android:layout_height="wrap_content"
                      android:layout_weight="1"
                      android:textStyle="bold"
                      android:text="@string/count"/>

                  </LinearLayout>
               </RelativeLayout>

               <RelativeLayout
                   android:id="@+id/rl_count"
                   android:layout_width="match_parent"
                   android:layout_height="66pt"
                   android:layout_marginLeft="@dimen/pt_10"
                   android:layout_marginTop="-20pt"
                   android:layout_marginRight="@dimen/pt_10"
                   android:orientation="horizontal"
                   app:layout_constraintLeft_toLeftOf="parent"
                   app:layout_constraintTop_toTopOf="parent">

                  <ImageView
                      android:id="@+id/rl_icon"
                      android:layout_width="@dimen/pt_20"
                      android:layout_height="@dimen/pt_20"
                      android:layout_centerVertical="true"
                      android:src="@drawable/bg_count"/>

                  <TextView
                      android:id="@+id/tv_count_hawks"
                      android:layout_width="wrap_content"
                      android:layout_height="wrap_content"
                      android:layout_centerVertical="true"
                      android:layout_marginStart="@dimen/pt_5"
                      android:layout_toEndOf="@id/rl_icon"
                      android:text="1100"
                      android:textColor="@color/color_101828"
                      android:textSize="@dimen/sp_24"
                      android:textStyle="bold"/>
               </RelativeLayout>

               <androidx.cardview.widget.CardView
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:layout_marginLeft="@dimen/dp_10"
                   android:layout_marginRight="@dimen/dp_10"
                   app:cardCornerRadius="16dp"
                   app:cardElevation="@dimen/dp_6"
                   android:layout_marginBottom="@dimen/pt_5">

                  <androidx.constraintlayout.widget.ConstraintLayout
                      android:layout_width="match_parent"
                      android:layout_height="wrap_content"
                      android:padding="16dp">

                     <LinearLayout
                         android:id="@+id/layoutTitleAndButton"
                         android:layout_width="0dp"
                         android:layout_height="wrap_content"
                         android:orientation="horizontal"
                         android:gravity="center_vertical"
                         android:layout_marginBottom="@dimen/pt_7"
                         app:layout_constraintStart_toStartOf="parent"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintTop_toTopOf="parent"
                         app:layout_constraintBottom_toTopOf="@id/llDaysContainer">

                        <TextView
                            android:id="@+id/tvTitleCal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/count_title_cal"
                            android:textColor="@color/black"
                            android:textSize="@dimen/sp_16"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/btnCheckIn"
                            android:layout_width="@dimen/pt_70"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_checkin_button"
                            android:text="@string/count_btn_Check_In"
                            android:gravity="center"
                            android:textColor="@color/white"
                            android:textSize="@dimen/sp_16"
                            android:textStyle="bold"
                            android:layout_marginStart="12dp"/>
                     </LinearLayout>
                     <LinearLayout
                         android:id="@+id/llDaysContainer"
                         android:layout_width="0dp"
                         android:layout_height="wrap_content"
                         android:layout_marginTop="16dp"
                         android:baselineAligned="false"
                         android:orientation="horizontal"
                         android:weightSum="7"
                         app:layout_constraintEnd_toEndOf="parent"
                         app:layout_constraintStart_toStartOf="parent"
                         app:layout_constraintBottom_toBottomOf="parent">

                        <include
                            android:id="@+id/day1"
                            layout="@layout/item_checkin_day" />
                        <include
                            android:id="@+id/day2"
                            layout="@layout/item_checkin_day" />
                        <include
                            android:id="@+id/day3"
                            layout="@layout/item_checkin_day" />
                        <include
                            android:id="@+id/day4"
                            layout="@layout/item_checkin_day" />
                        <include
                            android:id="@+id/day5"
                            layout="@layout/item_checkin_day" />
                        <include
                            android:id="@+id/day6"
                            layout="@layout/item_checkin_day" />
                        <include
                            android:id="@+id/day7"
                            layout="@layout/item_checkin_day" />

                     </LinearLayout>

                  </androidx.constraintlayout.widget.ConstraintLayout>

               </androidx.cardview.widget.CardView>

            </LinearLayout>

         </FrameLayout>

         <LinearLayout
             android:layout_marginRight="@dimen/dp_10"
             android:layout_marginLeft="@dimen/dp_10"
             android:layout_marginTop="@dimen/dp_10"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/ll_gift_exchange"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pt_5"
                android:layout_weight="1"
                android:background="@drawable/bg_item_hot_count"
                android:orientation="vertical"
                android:paddingTop="@dimen/pt_5"
                android:paddingBottom="@dimen/pt_5"
                android:elevation="@dimen/dp_6">

               <ImageView
                   android:id="@+id/iv_gift_exchange"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:layout_marginStart="@dimen/pt_7"
                   android:layout_marginTop="@dimen/pt_5"
                   android:src="@drawable/ic_gift_redemption" />

               <TextView
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:layout_marginStart="@dimen/pt_7"
                   android:layout_marginTop="@dimen/dp_10"
                   android:layout_marginBottom="@dimen/pt_5"
                   android:ellipsize="end"
                   android:singleLine="true"
                   android:text="@string/count_gift_redemption"
                   android:textStyle="bold"
                   android:textColor="@color/color_4A5565"
                   android:textSize="@dimen/sp_14" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_activity_exchange"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingTop="@dimen/pt_5"
                android:paddingBottom="@dimen/pt_5"
                android:elevation="@dimen/dp_6"
                android:layout_margin="@dimen/pt_5"
                android:background="@drawable/bg_item_hot_count">

               <ImageView
                   android:id="@+id/iv_activity_exchange"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/ic_event_redemption"
                   android:layout_marginStart="@dimen/pt_7"
                   android:layout_marginTop="@dimen/pt_5" />

               <TextView
                   android:layout_marginTop="@dimen/dp_10"
                   android:textColor="@color/color_4A5565"
                   android:textSize="@dimen/sp_14"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:singleLine="true"
                   android:ellipsize="end"
                   android:text="@string/count_event_redemption"
                   android:textStyle="bold"
                   android:layout_marginStart="@dimen/pt_7"
                   android:layout_marginBottom="@dimen/pt_5"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_exchange_history"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingTop="@dimen/pt_5"
                android:paddingBottom="@dimen/pt_5"
                android:elevation="@dimen/dp_6"
                android:layout_margin="@dimen/pt_5"
                android:background="@drawable/bg_item_hot_count">

               <ImageView
                   android:id="@+id/iv_exchange_history"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:src="@drawable/ic_discount_coupon_redemption"
                   android:layout_marginStart="@dimen/pt_7"
                   android:layout_marginTop="@dimen/pt_5" />

               <TextView
                   android:layout_marginTop="@dimen/dp_10"
                   android:textColor="@color/color_4A5565"
                   android:textSize="@dimen/sp_14"
                   android:textStyle="bold"
                   android:layout_width="wrap_content"
                   android:layout_height="wrap_content"
                   android:singleLine="true"
                   android:ellipsize="end"
                   android:text="@string/count_exchange_history"
                   android:layout_marginStart="@dimen/pt_7"
                   android:layout_marginBottom="@dimen/pt_5"/>
            </LinearLayout>

         </LinearLayout>


         <RelativeLayout
             android:layout_marginLeft="@dimen/dp_20"
             android:layout_marginRight="@dimen/dp_20"
             android:layout_marginTop="@dimen/dp_30"
             android:layout_width="match_parent"
             android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/sp_16"
                android:textStyle="bold"
                android:textColor="@color/color_101828"
                android:text="@string/count_points_task"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/tv_list"
                android:layout_centerVertical="true"
                android:layout_alignParentRight="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/count_newest_to_oldest_date"
                android:textSize="16sp"
                android:textColor="@color/color_101828"
                android:drawableStart="@drawable/ic_count_back"
                android:drawablePadding="8dp"/>
         </RelativeLayout>

         <androidx.recyclerview.widget.RecyclerView
             android:id="@+id/title_list"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:layout_marginTop="@dimen/dp_25"
             app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

         <androidx.recyclerview.widget.RecyclerView
             android:id="@+id/girls_list"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:nestedScrollingEnabled="false"
             android:paddingBottom="@dimen/pt_7"
             android:clipToPadding="false"
             android:layout_marginTop="@dimen/pt_7" />

         <TextView
             android:id="@+id/tv_view_more"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:layout_marginBottom="@dimen/pt_10"
             android:gravity="center"
             android:padding="12dp"
             android:text="查看更多"
             android:textColor="@color/color_E2518D"
             android:textSize="14sp"
             android:visibility="gone"/>
      </LinearLayout>
   </androidx.core.widget.NestedScrollView>
   <FrameLayout
       android:id="@+id/top"
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:visibility="gone"
       android:elevation="10dp"
       app:layout_constraintEnd_toEndOf="parent"
       app:layout_constraintTop_toTopOf="parent"
       app:layout_constraintBottom_toBottomOf="parent"
       android:layout_marginEnd="16dp">

      <ImageView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:clickable="false"
          android:focusable="false"
          android:focusableInTouchMode="false"
          android:src="@drawable/count_01" />

      <ImageView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center"
          android:clickable="false"
          android:focusable="false"
          android:focusableInTouchMode="false"
          android:src="@drawable/count_02" />
   </FrameLayout>

   <FrameLayout
       android:layout_width="match_parent"
       android:layout_height="match_parent">

   <LinearLayout
       android:id="@+id/ll_empty"
       android:layout_width="match_parent"
       android:layout_height="0dp"
       android:layout_weight="1"
       android:gravity="center"
       android:orientation="vertical"
       android:visibility="gone"
       app:layout_constraintBottom_toBottomOf="parent"
       app:layout_constraintLeft_toLeftOf="parent"
       app:layout_constraintRight_toRightOf="parent"
       app:layout_constraintTop_toTopOf="parent">

      <ImageView
          android:layout_width="@dimen/pt_42"
          android:layout_height="@dimen/pt_54"
          android:src="@drawable/ic_none_records" />

      <View
          android:layout_width="match_parent"
          android:layout_height="@dimen/pt_8" />

      <TextView
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_gravity="center_horizontal"
          android:text="@string/count_none_records"
          android:textColor="@color/color_A3A3A3"
          android:textSize="@dimen/sp_14" />
   </LinearLayout>
   </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

