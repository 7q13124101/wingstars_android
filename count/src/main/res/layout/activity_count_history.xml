<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".activity.CountHistoryActivity">

    <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/ll_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/gradient_top">
        <RelativeLayout
            android:id="@+id/rl_top"
            android:layout_width="match_parent"
            android:layout_height="@dimen/pt_30">

            <RelativeLayout
                android:id="@+id/img_back"
                android:layout_width="@dimen/pt_70"
                android:layout_height="match_parent">

                <ImageView
                    android:layout_width="@dimen/pt_15"
                    android:layout_height="@dimen/pt_15"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/pt_10"
                    android:clickable="false"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:src="@drawable/ic_back_black" />
            </RelativeLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/count_win_points"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:textSize="@dimen/sp_16" />

        </RelativeLayout>

        <LinearLayout
            android:id="@+id/fl_top"
            android:layout_width="match_parent"
            android:layout_height="@dimen/pt_60"
            android:orientation="vertical"
            android:paddingTop="@dimen/pt_9"
            app:layout_constraintTop_toTopOf="parent">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/pt_20"
                android:layout_marginRight="@dimen/pt_20"
                android:layout_marginBottom="@dimen/pt_5"
                android:gravity="center"
                android:orientation="horizontal"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/rl_icon"
                    android:layout_width="@dimen/pt_20"
                    android:layout_height="@dimen/pt_20"
                    android:layout_centerInParent="true"
                    android:src="@drawable/bg_count_pink" />

                <TextView
                    android:id="@+id/tv_count_WS"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="@dimen/pt_8"
                    android:text="1000"
                    android:layout_toEndOf="@id/rl_icon"
                    android:textColor="@color/black"
                    android:textSize="@dimen/sp_24" />
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:layout_marginTop="@dimen/pt_5"
                android:gravity="center"
                android:text="有效期限 2026/10/31 09:00"
                android:textColor="@color/color_6A7282"
                android:textSize="@dimen/sp_12" />
        </LinearLayout>
    </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:orientation="horizontal"
            android:baselineAligned="false"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:id="@+id/btn_tab_obtained"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_obtained_records"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/pt_30"
                        android:gravity="center"
                        android:text="@string/count_obtained_records"
                        android:textColor="@color/color_4A5565"
                        android:textSize="@dimen/sp_16"
                        android:textStyle="bold"/>

                    <View
                        android:id="@+id/view_obtained_records_select"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/pt_2"
                        android:background="@color/color_E2518D" />
                </LinearLayout>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/btn_tab_usage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_usage_records"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/pt_30"
                        android:gravity="center"
                        android:text="@string/count_usage_records"
                        android:textColor="@color/color_4A5565"
                        android:textSize="@dimen/sp_16" />

                    <View
                        android:id="@+id/view_usage_records_select"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/pt_2"
                        android:background="@color/white" />
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

        <com.scwang.smart.refresh.layout.SmartRefreshLayout
            android:id="@+id/srl_obtained_record"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="visible">

            <com.scwang.smart.refresh.header.ClassicsHeader
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:srlTextFailed="@string/refresh_failed"
                app:srlTextFinish="@string/refresh_success"
                app:srlTextPulling="@string/pull_down_to_refresh"
                app:srlTextRefreshing="@string/refreshing"
                app:srlTextRelease="@string/release_to_refresh"
                app:srlTextUpdate="@string/last_update" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/ad_obtained_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/pt_20"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_count_records" />
        </com.scwang.smart.refresh.layout.SmartRefreshLayout>

        <com.scwang.smart.refresh.layout.SmartRefreshLayout
            android:id="@+id/srl_usage_record"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone">

            <com.scwang.smart.refresh.header.ClassicsHeader
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:srlTextFailed="@string/refresh_failed"
                app:srlTextFinish="@string/refresh_success"
                app:srlTextPulling="@string/pull_down_to_refresh"
                app:srlTextRefreshing="@string/refreshing"
                app:srlTextRelease="@string/release_to_refresh"
                app:srlTextUpdate="@string/last_update" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/ad_usage_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/pt_20"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_count_records" />
        </com.scwang.smart.refresh.layout.SmartRefreshLayout>

    <LinearLayout
        android:id="@+id/ll_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="@dimen/pt_42"
            android:layout_height="@dimen/pt_54"
            android:src="@drawable/ic_none_records" />

        <View
            android:layout_width="match_parent"
            android:layout_height="@dimen/pt_8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/count_none_records"
            android:textColor="@color/color_A3A3A3"
            android:textSize="@dimen/sp_14" />
    </LinearLayout>
</LinearLayout>
</layout>