<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_login"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        tools:context=".login.LoginActivity">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/pt_10"
            android:paddingHorizontal="@dimen/dp_20">
            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_arrow_left" />


<!--            <TextView-->
<!--                android:id="@+id/tv_close"-->
<!--                android:layout_width="wrap_content"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:layout_alignParentRight="true"-->
<!--                android:layout_centerVertical="true"-->
<!--                android:layout_marginRight="@dimen/pt_20"-->
<!--                android:paddingTop="@dimen/pt_16"-->
<!--                android:paddingBottom="@dimen/pt_9"-->
<!--                android:text="@string/login_close"-->
<!--                android:textColor="@color/white"-->
<!--                android:textSize="@dimen/sp_18"-->
<!--                android:visibility="gone"/>-->

            <ImageView
                android:id="@+id/iv_close"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_close" />



        </RelativeLayout>

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="113dp"
            android:layout_height="78dp"
            android:layout_marginBottom="@dimen/dp_50"
            android:layout_marginTop="52dp"
            android:src="@drawable/ic_logo_login" />

        <androidx.core.widget.NestedScrollView
            android:id="@+id/scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/bg_login_layout"
            android:fillViewport="true"
            android:paddingHorizontal="@dimen/dp_30"
            android:paddingVertical="@dimen/dp_30"
            android:clipToOutline="true"
            android:elevation="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/welcome_login"
                    android:textColor="@color/text_subtitle"
                    android:textSize="@dimen/sp_18"/>


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="left"
                        android:layout_marginBottom="10dp"
                        android:text="@string/account"
                        android:textColor="@color/text_tittle"
                        android:textSize="@dimen/sp_14" />

                    <RelativeLayout
                        android:id="@+id/rl_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input_selector"
                        android:addStatesFromChildren="true"
                        android:paddingLeft="@dimen/dp_20"
                        android:paddingTop="16dp"
                        android:paddingRight="@dimen/dp_20"
                        android:paddingBottom="16dp"
                        android:visibility="visible">


                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/edt_phone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="@string/hint_phone"
                            android:imeOptions="actionNext"
                            android:nextFocusForward="@id/edt_psd"
                            android:singleLine="true"
                            android:textColor="@color/text_subtitle"
                            android:textColorHint="@color/gray_400"
                            android:textSize="@dimen/sp_14" />
                        <ImageView
                            android:id="@+id/alert_circle"
                            android:layout_width="@dimen/dp_20"
                            android:layout_height="@dimen/dp_20"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/alert_circle"
                            android:visibility="invisible"/>

                    </RelativeLayout>
                    <RelativeLayout
                        android:id="@+id/rl_phone_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/form__error"
                        android:paddingLeft="@dimen/dp_20"
                        android:paddingTop="@dimen/dp_17"
                        android:paddingRight="@dimen/dp_20"
                        android:paddingBottom="@dimen/dp_17"
                        android:visibility="gone">


                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/edt_phone_error"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="@string/hint_phone"
                            android:imeOptions="actionNext"
                            android:nextFocusForward="@id/edt_psd"
                            android:singleLine="true"
                            android:textColor="@color/text_subtitle"
                            android:textColorHint="@color/gray_400"
                            android:textSize="@dimen/sp_14" />



                    </RelativeLayout>
                    <TextView
                        android:id="@+id/tv_phone_input_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/color_FB2C36"
                        android:textSize="@dimen/sp_12"
                        android:text="@string/error_format"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:visibility="invisible"
                        />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="left"
                        android:layout_marginBottom="10dp"
                        android:text="@string/password"
                        android:textColor="@color/text_tittle"
                        android:textSize="@dimen/sp_14" />

                    <RelativeLayout
                        android:id="@+id/rl_psd"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_input_selector"
                        android:addStatesFromChildren="true"                        android:paddingLeft="@dimen/dp_20"
                        android:paddingTop="@dimen/dp_17"
                        android:paddingRight="@dimen/dp_20"
                        android:paddingBottom="@dimen/dp_17"
                        android:visibility="visible">

                        <androidx.appcompat.widget.AppCompatCheckBox
                            android:id="@+id/cb_psd_visible"
                            android:layout_width="@dimen/dp_20"
                            android:layout_height="@dimen/dp_20"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:button="@drawable/checkbox_psd_visible"
                            android:checked="false" />

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/edt_psd"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_toLeftOf="@id/cb_psd_visible"
                            android:background="@null"
                            android:hint="@string/hint_psd"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:singleLine="true"
                            android:textColor="@color/text_tittle"
                            android:textColorHint="@color/gray_400"
                            android:textSize="@dimen/sp_14" />

                    </RelativeLayout>
                    <RelativeLayout
                        android:id="@+id/rl_psd_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/form__error"
                        android:paddingLeft="@dimen/dp_20"
                        android:paddingTop="@dimen/dp_17"
                        android:paddingRight="@dimen/dp_20"
                        android:paddingBottom="@dimen/dp_17"
                        android:visibility="gone">


                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/edt_psd_error"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@null"
                            android:hint="@string/hint_phone"
                            android:imeOptions="actionNext"
                            android:nextFocusForward="@id/edt_psd"
                            android:singleLine="true"
                            android:textColor="@color/text_subtitle"
                            android:textColorHint="@color/gray_400"
                            android:textSize="@dimen/sp_14" />
                        <ImageView
                            android:layout_width="@dimen/dp_20"
                            android:layout_height="@dimen/dp_20"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/alert_circle"
                            android:visibility="visible"/>

                    </RelativeLayout>
                    <TextView
                        android:id="@+id/tv_psd_input_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/color_FB2C36"
                        android:textSize="@dimen/sp_12"
                        android:text="@string/error_format"
                        android:ellipsize="end"
                        android:includeFontPadding="false"
                        android:visibility="invisible"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical">

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/cb_psd"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:button="@drawable/checkboxes_remember_pw"
                        android:checked="false" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="8dp"
                        android:text="@string/remember_psd"
                        android:textColor="@color/text_tittle"
                        android:textSize="@dimen/sp_14" />


                </LinearLayout>


                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_login"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:background="@drawable/bg_button_login"
                    android:elevation="0dp"
                    android:stateListAnimator="@null"
                    android:text="@string/login"
                    android:textColor="@color/white"
                    android:textSize="@dimen/sp_14"
                    app:backgroundTint="@null" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="34dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_forget_psd"
                        android:layout_width="@dimen/pt_0"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/forget_psd"
                        android:textColor="@color/text_subtitle"
                        android:textSize="@dimen/sp_14" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="|"
                        android:textColor="@color/text_subtitle"
                        android:textSize="@dimen/sp_14" />

                    <TextView
                        android:id="@+id/tv_register"
                        android:layout_width="@dimen/pt_0"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/user_register"
                        android:textColor="@color/text_subtitle"
                        android:textSize="@dimen/sp_14" />

                </LinearLayout>
                <!--                <TextView-->
                <!--                    android:id="@+id/tv_close"-->
                <!--                    android:layout_width="wrap_content"-->
                <!--                    android:layout_height="wrap_content"-->
                <!--                    android:paddingTop="@dimen/pt_30"-->
                <!--                    android:paddingBottom="@dimen/pt_9"-->
                <!--                    android:text="@string/login_close"-->
                <!--                    android:textColor="@color/color_B81B30"-->
                <!--                    android:layout_gravity="center"-->
                <!--                    android:textSize="@dimen/sp_14" />-->

            </LinearLayout>


        </androidx.core.widget.NestedScrollView>



    </LinearLayout>
</layout>
