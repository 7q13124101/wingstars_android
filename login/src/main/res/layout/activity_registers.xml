<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:context="com.wingstars.register.RegisterActivity">


        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_64"
            android:background="@color/white">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/register_terms"
                android:textColor="@color/text_tittle"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold"/>

            <RelativeLayout
                android:id="@+id/iv_close"
                android:layout_width="@dimen/dp_70"
                android:layout_height="match_parent">

                <ImageView
                    android:layout_width="@dimen/dp_30"
                    android:layout_height="@dimen/dp_30"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="@dimen/dp_20"
                    android:clickable="false"
                    android:focusable="false"
                    android:focusableInTouchMode="false"
                    android:src="@drawable/ic_arrow_left"
                    android:visibility="visible" />
            </RelativeLayout>

        </RelativeLayout>


        <androidx.core.widget.NestedScrollView
            android:id="@+id/ns_register"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/white"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="@dimen/dp_20"
                android:paddingRight="@dimen/dp_20">

                <TextView
                    android:layout_marginTop="@dimen/dp_10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/phone"
                    android:textColor="@color/text_tittle"
                    android:textSize="@dimen/sp_14" />

                <RelativeLayout
                    android:id="@+id/rl_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:addStatesFromChildren="true"
                    android:background="@drawable/bg_input_selector"
                    android:paddingStart="@dimen/dp_20"
                    android:paddingTop="@dimen/dp_17"
                    android:paddingEnd="@dimen/dp_20"
                    android:paddingBottom="@dimen/dp_17">
                    <FrameLayout
                        android:layout_alignParentRight="true"
                        android:id="@+id/send_code"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_gravity="center"
                            android:id="@+id/btn_send_code"
                            android:layout_width="wrap_content"
                            android:layout_height="25dp"
                            android:background="@drawable/bg_sends_code"
                            android:paddingStart="@dimen/dp_12"
                            android:paddingEnd="@dimen/dp_12"
                            android:text="@string/send_phone_code"
                            android:textAlignment="center"
                            android:textColor="@color/text_tittle"
                            android:textSize="@dimen/sp_14"
                            android:visibility="visible" />

                        <RelativeLayout
                            android:layout_gravity="center"
                            android:id="@+id/rl_code_timer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone">

                            <TextView
                                android:layout_centerVertical="true"
                                android:id="@+id/tv_code_timer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="59s"
                                android:textColor="@color/color_E2518D"
                                android:textSize="@dimen/sp_12" />

                            <TextView
                                android:layout_centerVertical="true"
                                android:id="@+id/tv_resend"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_toEndOf="@id/tv_code_timer"
                                android:text=" 重新傳送"
                                android:textColor="@color/text_subtitle"
                                android:textSize="@dimen/sp_12" />
                        </RelativeLayout>

                    </FrameLayout>




                    <androidx.appcompat.widget.AppCompatEditText
                        android:layout_marginRight="@dimen/dp_20"
                        android:layout_toLeftOf="@id/send_code"
                        android:id="@+id/edt_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:background="@null"
                        android:hint="@string/hint_phone_register"
                        android:imeOptions="actionNext"
                        android:inputType="phone"
                        android:nextFocusForward="@id/edt_phone_code"
                        android:singleLine="true"
                        android:textColor="@color/text_tittle"
                        android:textColorHint="@color/gray_400"
                        android:textSize="@dimen/sp_14" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/tv_phone_input_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:text="@string/error_format"
                    android:textColor="@color/color_FB2C36"
                    android:textSize="@dimen/sp_12"
                    android:visibility="invisible" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:text="@string/phone_code"
                    android:textColor="@color/text_tittle"
                    android:textSize="@dimen/sp_14" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:addStatesFromChildren="true"
                    android:background="@drawable/bg_input_selector"
                    android:paddingLeft="@dimen/dp_20"
                    android:paddingTop="@dimen/dp_17"
                    android:paddingRight="@dimen/dp_20"
                    android:paddingBottom="@dimen/dp_17">

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/edt_phone_code"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/hint_phone_code_register"
                        android:imeOptions="actionNext"
                        android:inputType="number"
                        android:nextFocusForward="@id/edt_psd"
                        android:singleLine="true"
                        android:textColor="@color/text_tittle"
                        android:textColorHint="@color/gray_400"
                        android:textSize="@dimen/sp_14" />
                </RelativeLayout>
                <!--                    android:id="@+id/tv_error_name"-->
                <!--                    android:layout_width="wrap_content"-->
                <!--                    android:layout_height="wrap_content"-->
                <!--                    android:layout_marginTop="4dp"-->
