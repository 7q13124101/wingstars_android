        <LinearLayout
            android:id="@+id/ll_register_finish"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/white"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="@dimen/pt_190"
                android:layout_height="@dimen/pt_190"
                android:src="@drawable/ic_takamei" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_17"
                android:gravity="center"
                android:paddingLeft="@dimen/dp_17"
                android:paddingRight="@dimen/dp_17"
                android:text="@string/register_finish_1"
                android:textColor="@color/text_tittle"
                android:textSize="@dimen/sp_18"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_17"
                android:gravity="center"
                android:paddingLeft="@dimen/dp_17"
                android:paddingRight="@dimen/dp_17"
                android:text="@string/register_finish_2"
                android:textColor="@color/text_tittle"
                android:textSize="@dimen/sp_14" />

        </LinearLayout>

        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_57"
            android:textSize="@dimen/sp_14"
            android:textColor="@color/gray_500"
            android:text="@string/next_step"
            android:gravity="center"
            android:background="@color/gray_200"/>

        <View
            android:id="@+id/bottom_view"
            android:background="@color/gray_200"
            android:layout_width="match_parent"
            android:layout_height="0dp"/>
    </LinearLayout>

</layout>
