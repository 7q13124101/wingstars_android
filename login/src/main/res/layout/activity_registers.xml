<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        tools:context="com.wingstars.register.RegisterActivity">

        <RelativeLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_64"
            android:background="@color/white"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="@string/register_terms"
                android:textColor="@color/text_tittle"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold"/>

            <RelativeLayout
                android:id="@+id/iv_close"
                android:layout_width="@dimen/dp_70"
                android:layout_height="match_parent">

                <ImageView
                    android:layout_width="@dimen/dp_30"
                    android:layout_height="@dimen/dp_30"
                    android:layout_centerVertical="true"
                    android:layout_marginLeft="@dimen/dp_20"
                    android:src="@drawable/ic_arrow_left"
                    android:visibility="visible" />
            </RelativeLayout>
        </RelativeLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/ns_register"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/white"
            android:scrollbars="none"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintBottom_toTopOf="@id/btn_confirm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingLeft="@dimen/dp_20"
                android:paddingRight="@dimen/dp_20">

                <TextView
                    android:layout_marginTop="@dimen/dp_10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/phone"
                    android:textColor="@color/text_tittle"
                    android:textSize="@dimen/sp_14" />

                <RelativeLayout
                    android:id="@+id/rl_phone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:addStatesFromChildren="true"
                    android:background="@drawable/bg_input_selector"
                    android:paddingStart="@dimen/dp_20"
                    android:paddingTop="@dimen/dp_17"
                    android:paddingEnd="@dimen/dp_20"
                    android:paddingBottom="@dimen/dp_17">
                    <FrameLayout
                        android:layout_alignParentRight="true"
                        android:id="@+id/send_code"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">
                        <androidx.appcompat.widget.AppCompatButton
                            android:layout_gravity="center"
                            android:id="@+id/btn_send_code"
                            android:layout_width="wrap_content"
                            android:layout_height="25dp"
                            android:background="@drawable/bg_sends_code"
                            android:paddingStart="@dimen/dp_12"
                            android:paddingEnd="@dimen/dp_12"
                            android:text="@string/send_phone_code"
                            android:textAlignment="center"
                            android:textColor="@color/text_tittle"
                            android:textSize="@dimen/sp_14"
                            android:visibility="visible" />

                        <RelativeLayout
                            android:layout_gravity="center"
                            android:id="@+id/rl_code_timer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:visibility="gone">

                            <TextView
                                android:layout_centerVertical="true"
                                android:id="@+id/tv_code_timer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="59s"
                                android:textColor="@color/color_E2518D"
                                android:textSize="@dimen/sp_12" />

                            <TextView
                                android:layout_centerVertical="true"
                                android:id="@+id/tv_resend"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:paddingHorizontal="8dp"
                                android:paddingVertical="4dp"
                                android:layout_toEndOf="@id/tv_code_timer"
                                android:text=" 重新傳送"
                                android:textColor="@color/text_subtitle"
                                android:textSize="@dimen/sp_12" />
                        </RelativeLayout>

                    </FrameLayout>

                    <androidx.appcompat.widget.AppCompatEditText
                        android:layout_marginRight="@dimen/dp_20"
                        android:layout_toLeftOf="@id/send_code"
                        android:id="@+id/edt_phone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:background="@null"
                        android:hint="@string/hint_phone_register"
                        android:imeOptions="actionNext"
                        android:inputType="phone"
                        android:nextFocusForward="@id/edt_phone_code"
                        android:singleLine="true"
                        android:textColor="@color/text_tittle"
                        android:textColorHint="@color/gray_400"
                        android:textSize="@dimen/sp_14" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/tv_phone_input_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:text="@string/error_format"
                    android:textColor="@color/color_FB2C36"
                    android:textSize="@dimen/sp_12"
                    android:visibility="invisible" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:text="@string/phone_code"
                    android:textColor="@color/text_tittle"
                    android:textSize="@dimen/sp_14" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:addStatesFromChildren="true"
                    android:background="@drawable/bg_input_selector"
                    android:paddingLeft="@dimen/dp_20"
                    android:paddingTop="@dimen/dp_17"
                    android:paddingRight="@dimen/dp_20"
                    android:paddingBottom="@dimen/dp_17">

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/edt_phone_code"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/hint_phone_code_register"
                        android:imeOptions="actionNext"
                        android:inputType="number"
                        android:nextFocusForward="@id/edt_psd"
                        android:singleLine="true"
                        android:textColor="@color/text_tittle"
                        android:textColorHint="@color/gray_400"
                        android:textSize="@dimen/sp_14" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_20"
                    android:text="@string/password"
                    android:textColor="@color/text_tittle"
                    android:textSize="@dimen/sp_14" />

                <RelativeLayout
                    android:id="@+id/rl_psd"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:addStatesFromChildren="true"
                    android:background="@drawable/bg_input_selector"
                    android:paddingLeft="@dimen/dp_20"
                    android:paddingTop="@dimen/dp_17"
                    android:paddingRight="@dimen/dp_20"
                    android:paddingBottom="@dimen/dp_17">

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/cb_psd_visible"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:button="@drawable/checkbox_psd_visible"
                        android:checked="false" />

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/edt_psd"
                        android:layout_marginRight="@dimen/dp_20"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toLeftOf="@id/cb_psd_visible"
                        android:background="@null"
                        android:hint="@string/hint_psd"
                        android:imeOptions="actionNext"
                        android:inputType="textPassword"
                        android:nextFocusForward="@id/edt_psd_confirm"
                        android:singleLine="true"
                        android:textColor="@color/text_tittle"
                        android:textColorHint="@color/gray_400"
                        android:letterSpacing="0.1"
                        android:typeface="sans"
                        android:textSize="@dimen/sp_14" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/tv_psd_input_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:text="@string/note_register_psd"
                    android:textColor="@color/gray_400"
                    android:textSize="@dimen/sp_12"
                    android:visibility="visible" />


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:text="@string/register_psd_confirm"
                    android:textColor="@color/text_tittle"
                    android:textSize="@dimen/sp_14" />

                <RelativeLayout
                    android:id="@+id/rl_psd_confirm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:addStatesFromChildren="true"
                    android:background="@drawable/bg_input_selector"
                    android:paddingLeft="@dimen/dp_20"
                    android:paddingTop="@dimen/dp_17"
                    android:paddingRight="@dimen/dp_20"
                    android:paddingBottom="@dimen/dp_17">

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/cb_psd_confirm_visible"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:button="@drawable/checkbox_psd_visible"
                        android:checked="false" />

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/edt_psd_confirm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_toLeftOf="@id/cb_psd_confirm_visible"
                        android:background="@null"
                        android:hint="@string/hint_input_new_psd_again"
                        android:imeOptions="actionNext"
                        android:inputType="textPassword"
                        android:nextFocusForward="@id/edt_name"
                        android:singleLine="true"
                        android:textColor="@color/text_tittle"
                        android:textColorHint="@color/gray_400"
                        android:letterSpacing="0.1"
                        android:typeface="sans"
                        android:textSize="@dimen/sp_14" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/tv_psd_reinput_error"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:ellipsize="end"
                    android:includeFontPadding="false"
                    android:text="@string/error_format"
                    android:textColor="@color/color_FB2C36"
                    android:textSize="@dimen/sp_12"
                    android:visibility="invisible" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:text="@string/name"
                    android:textColor="@color/text_tittle"
                    android:textSize="@dimen/sp_14" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:addStatesFromChildren="true"
                    android:background="@drawable/bg_input_selector"
                    android:paddingLeft="@dimen/dp_20"
                    android:paddingTop="@dimen/dp_17"
                    android:paddingRight="@dimen/dp_20"
                    android:paddingBottom="@dimen/dp_17">

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/edt_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/hint_name"
                        android:imeOptions="actionNext"
                        android:nextFocusForward="@id/edt_email"
                        android:singleLine="true"
                        android:textColor="@color/text_tittle"
                        android:textColorHint="@color/gray_400"
                        android:textSize="@dimen/sp_14" />
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_20"
                    android:text="@string/email"
                    android:textColor="@color/text_tittle"
                    android:textSize="@dimen/sp_14" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_8"
                    android:addStatesFromChildren="true"
                    android:background="@drawable/bg_input_selector"
                    android:paddingLeft="@dimen/dp_20"
                    android:paddingTop="@dimen/dp_17"
                    android:paddingRight="@dimen/dp_20"
                    android:paddingBottom="@dimen/dp_17">

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/edt_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@null"
                        android:hint="@string/hint_email"
                        android:imeOptions="actionNext"
                        android:singleLine="true"
                        android:textColor="@color/text_tittle"
                        android:textColorHint="@color/gray_400"
                        android:textSize="@dimen/sp_14" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/dp_20"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/sex"
                        android:textColor="@color/text_tittle"
                        android:textSize="@dimen/sp_14" />

                    <ImageView
                        android:id="@+id/iv_sex_circle"
                        android:layout_width="@dimen/dp_20"
                        android:layout_height="@dimen/dp_20"
                        android:layout_marginLeft="@dimen/pt_6"
                        android:src="@drawable/information_circle" />
                </LinearLayout>

                <RadioGroup
                    android:id="@+id/rg_sex"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/pt_22"
                    android:layout_marginTop="@dimen/dp_8"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatRadioButton
                        android:id="@+id/rb_sex_male"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:button="@null"
                        android:checked="true"
                        android:drawableLeft="@drawable/checkboxes__sexs"
                        android:drawablePadding="10dp"
                        android:text="@string/sex_male"
                        android:textColor="#4A5565" />

                    <View
                        android:layout_width="@dimen/dp_24"
                        android:layout_height="match_parent" />

                    <androidx.appcompat.widget.AppCompatRadioButton
                        android:id="@+id/rb_sex_female"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:button="@null"
                        android:checked="false"
                        android:drawableLeft="@drawable/checkboxes__sexs"
                        android:drawablePadding="10dp"
                        android:text="@string/sex_female"
                        android:textColor="#4A5565" />

                    <View
                        android:layout_width="@dimen/dp_24"
                        android:layout_height="match_parent" />

                    <androidx.appcompat.widget.AppCompatRadioButton
                        android:id="@+id/rb_sex_secrecy"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:background="@null"
                        android:button="@null"
                        android:checked="false"
                        android:drawableLeft="@drawable/checkboxes__sexs"
                        android:drawablePadding="10dp"
                        android:text="@string/sex_secrecy"
                        android:textColor="#4A5565" />
                </RadioGroup>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp">

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/rb_privacy_policy"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_centerVertical="true"
                        android:button="@drawable/checkboxes_remember_pw"
                        android:checked="false"
                        android:paddingStart="@dimen/dp_20"
                        android:text="@string/privacy_policy"
                        android:textColor="#101828" />

                    <TextView
                        android:id="@+id/privacy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:text="查看"
                        android:textColor="@color/color_E2518D" />

                </RelativeLayout>

                <RelativeLayout
                    android:layout_marginTop="@dimen/dp_12"
                    android:layout_marginBottom="@dimen/dp_68"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/rb_user_terms"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_centerVertical="true"
                        android:background="@null"
                        android:button="@drawable/checkboxes_remember_pw"
                        android:checked="false"
                        android:drawablePadding="12dp"
                        android:paddingStart="20dp"
                        android:text="@string/user_agreement"
                        android:textColor="#101828" />

                    <TextView
                        android:id="@+id/agreement"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:text="查看"
                        android:textColor="@color/color_E2518D" />
                </RelativeLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/ll_register_finish"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/white"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintBottom_toTopOf="@id/btn_confirm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <ImageView
                android:layout_width="@dimen/pt_190"
                android:layout_height="@dimen/pt_190"
                android:src="@drawable/ic_takamei_success" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_17"
                android:gravity="center"
                android:paddingLeft="@dimen/dp_17"
                android:paddingRight="@dimen/dp_17"
                android:text="@string/register_finish_1"
                android:textColor="@color/text_tittle"
                android:textSize="@dimen/sp_18"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_17"
                android:gravity="center"
                android:paddingLeft="@dimen/dp_17"
                android:paddingRight="@dimen/dp_17"
                android:text="@string/register_finish_2"
                android:textColor="@color/text_tittle"
                android:textSize="@dimen/sp_14" />

        </LinearLayout>

        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp_57"
            android:textSize="@dimen/sp_14"
            android:textColor="@color/gray_500"
            android:text="確定"
            android:gravity="center"
            android:background="@color/gray_200"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>