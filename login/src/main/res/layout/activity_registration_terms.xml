                        android:textColor="@color/text_subtitle"
                        android:textSize="@dimen/sp_14" />

                    <TextView
                        android:id="@+id/tvGenderPurpose2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/pt_4"
                        android:drawableLeft="@drawable/icon_dots_black"
                        android:drawablePadding="8dp"
                        android:gravity="center_vertical"
                        android:text="可能用於特定會員活動，讓您獲得更符合需求的專屬服務。"
                        android:textColor="@color/text_subtitle"
                        android:textSize="@dimen/sp_14" />

                    <TextView
                        android:id="@+id/tvGenderPrivacyLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_20"
                        android:text="隱私保障："
                        android:textColor="@color/text_tittle"
                        android:textStyle="bold"
                        android:textSize="@dimen/sp_14" />

                    <TextView
                        android:id="@+id/tvGenderPrivacy1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/pt_4"
                        android:drawableLeft="@drawable/icon_dots_black"
                        android:drawablePadding="8dp"
                        android:gravity="center_vertical"
                        android:text="此資訊僅作為內部分析與服務優化，不會對外公開或與第三方共享。"
                        android:textColor="@color/text_subtitle"
                        android:textSize="@dimen/sp_14" />
                </LinearLayout>

                <!-- 隱私權保護承諾 -->
                <LinearLayout
                    android:id="@+id/llPrivacyCommitHeader"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/color_F5F5F5"
                    android:orientation="vertical"
                    android:paddingLeft="@dimen/dp_20"
                    android:paddingTop="@dimen/pt_10"
                    android:paddingRight="@dimen/dp_20"
                    android:paddingBottom="@dimen/pt_10">

                    <TextView
                        android:id="@+id/tvPrivacyCommitTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="隱私權保護承諾"
                        android:textColor="@color/text_tittle"
                        android:textSize="@dimen/sp_14"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llPrivacyCommitCard"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="@dimen/dp_20"
                    android:layout_marginBottom="@dimen/dp_20"
