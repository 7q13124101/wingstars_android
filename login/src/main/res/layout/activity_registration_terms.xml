                    <TextView
                        android:id="@+id/tvPrivacyCommit2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/pt_4"
                        android:drawableLeft="@drawable/icon_dots_black"
                        android:drawablePadding="8dp"
                        android:gravity="center_vertical"
                        android:text="所有個人資訊均採取加密儲存，並符合 個人資料保護法及相關資安規範。"
                        android:textColor="@color/text_subtitle"
                        android:textSize="@dimen/sp_14" />

                    <TextView
                        android:id="@+id/tv_privacy_policy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/pt_4"
                        android:drawableLeft="@drawable/icon_dots_black"
                        android:drawablePadding="8dp"
                        android:gravity="center_vertical"
                        android:text="您可隨時透過隱私權政策了解更多資訊，並管理您的個人資料使用權限。"
                        android:textColor="@color/text_subtitle"
                        android:textSize="@dimen/sp_14" />

                    <TextView
                        android:id="@+id/tvPrivacyContact"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
