<resources>
    <style name="Theme.WingStars.Register" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@color/color_e5e7eb</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:fontFamily">@font/noto_sans_tc</item>

        <item name="bottomSheetDialogTheme">@style/MyBottomSheetDialogTheme</item>
    </style>

    <style name="MyBottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@drawable/bg_bottom_sheet_rounded</item>
    </style>

    <style name="MyBottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/MyBottomSheetStyle</item>

        <item name="android:windowIsFloating">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/white</item>
        <item name="android:fontFamily">@font/noto_sans_tc</item>
    </style>

</resources>