<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_event_details"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp_211"
        android:layout_marginTop="@dimen/dp_20"
        android:background="@drawable/calendar_bg_radius_white"
        android:orientation="horizontal">

        <androidx.cardview.widget.CardView
            android:id="@+id/img_general_card"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/dp_20"
            android:elevation="0dp"
            android:shadowRadius="0"
            app:cardCornerRadius="@dimen/dp_8"
            app:cardElevation="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/iv_general_photo"
                android:layout_width="@dimen/dp_137"
                android:layout_height="@dimen/dp_171"
                android:scaleType="centerCrop"
                android:src="@drawable/calendar_ic_photo" />

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/dp_16"
            android:layout_marginEnd="@dimen/dp_8"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="@id/img_general_card"
            app:layout_constraintLeft_toRightOf="@id/img_general_card"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="@id/img_general_card">

            <TextView
                android:id="@+id/tv_general_name"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:text="心動時刻\n✨Stars House 快閃預告✨"
                android:textColor="@color/color_000000"
                android:textSize="@dimen/sp_16"
                android:textStyle="bold" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/iv_general_type"
                    android:layout_width="@dimen/dp_63"
                    android:layout_height="@dimen/dp_72"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:src="@drawable/calendar_ic_star" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentBottom="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_general_activity_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2025-09-25 14:00 ~ 2025-09-28 18:35"
                        android:textColor="@color/color_4A5565"
                        android:textSize="@dimen/sp_14" />

                    <TextView
                        android:id="@+id/tv_general_map"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_8"
                        android:text="臺北大巨蛋"
                        android:textColor="@color/color_DE9DBA"
                        android:textSize="@dimen/sp_14"
                        android:textStyle="bold" />
                </LinearLayout>

            </RelativeLayout>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>